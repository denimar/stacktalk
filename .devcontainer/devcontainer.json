{
  "name": "Stacktalk",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "forwardPorts": [3006],
  "portsAttributes": {
    "3006": {
      "label": "Dev Server",
      "onAutoForward": "notify",
      "visibility": "public"
    }
  },
  "postCreateCommand": "npm install && npx prisma generate",
  "customizations": {
    "codespaces": {
      "openFiles": []
    }
  }
}
